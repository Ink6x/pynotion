# 環境変数のサンプル。コピーして .env を作る (`.env` は git 管理外)。
# dev(config.settings.dev)では全て省略可。
# prod(config.settings.prod)では以下 3 つが必須。

# 50 文字以上のランダム文字列。生成例:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# カンマ区切り (例: example.com,www.example.com)
DJANGO_ALLOWED_HOSTS=

# 例: postgres://pynotion:password@db:5432/pynotion
DATABASE_URL=

# 任意: CSRF 信頼オリジン (例: https://example.com)
DJANGO_CSRF_TRUSTED_ORIGINS=

# 任意: Redis (prod でキャッシュ / レート制限 / healthz 疎通に使う)
REDIS_URL=

# 任意: 書き込み系 API のレート制限 (既定 120/m)
WRITE_RATELIMIT=

# 任意: ページツリーキャッシュの TTL 秒 (既定 300)
PAGE_TREE_CACHE_TTL=

# 任意(dev のみ): 1 で django-debug-toolbar を有効化
DEBUG_TOOLBAR=
